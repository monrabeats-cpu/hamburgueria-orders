# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Groq (LLM para atendimento via WhatsApp)
GROQ_API_KEY=your-groq-api-key

# App URL (deve ser identico ao webhook configurado no Twilio)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Mercado Pago (PIX)
# Access Token: Mercado Pago Dashboard > Credenciais > Access Token
MP_ACCESS_TOKEN=APP_USR-your-access-token
# Webhook Secret: Mercado Pago Dashboard > Suas integrações > Webhooks > Chave secreta
MP_WEBHOOK_SECRET=your-webhook-secret
